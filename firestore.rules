rules_version = '2';

// Deploy: firebase deploy --only firestore:rules
// Enable Anonymous sign-in in Firebase Console for "preview host" on web.

service cloud.firestore {
  match /databases/{database}/documents {

    match /hosts/{hostId} {
      allow read: if resource.data.listingStatus == 'published'
        || (request.auth != null && request.auth.uid == hostId);

      allow create, update: if request.auth != null
        && request.auth.uid == hostId
        && request.resource.data.userId == request.auth.uid;

      allow delete: if request.auth != null && request.auth.uid == hostId;
    }

    match /trust_profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
